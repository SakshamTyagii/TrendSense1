# ============================================
# TrendSense - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys

# NEWS API - Get your key at https://newsapi.org/
VITE_NEWS_API_KEY=your_newsapi_key_here

# OPENAI - Get your key at https://platform.openai.com/
VITE_OPENAI_API_KEY=your_openai_key_here

# GOOGLE OAUTH - Get credentials at https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# YOUTUBE DATA API - Get your key at https://console.cloud.google.com/
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# ELEVENLABS TTS - Get your key at https://elevenlabs.io/
VITE_ELEVENLABS_API_KEY=your_elevenlabs_key_here

# TWITTER/X OAuth (Optional)
VITE_TWITTER_CLIENT_ID=your_twitter_client_id_here
VITE_TWITTER_CLIENT_SECRET=your_twitter_secret_here
